<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp"
    android:orientation="vertical">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/widget_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00 PM"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SUN, FEB 15"
            android:textColor="#94a3b8"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginLeft="12dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPENSOAK"
            android:textColor="#60a5fa"
            android:textSize="12sp"
            android:textStyle="bold" />
        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginLeft="12dp"
            android:src="@android:drawable/ic_menu_rotate" />
    </LinearLayout>

    <!-- Session Row -->
    <LinearLayout
        android:id="@+id/widget_active_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:background="@drawable/status_pill"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical"
        android:visibility="gone">
        <TextView
            android:id="@+id/widget_active_session"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NIGHTLY SOAK"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_session_times"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6:00 PM - 8:00 PM"
            android:textColor="#94a3b8"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginRight="12dp" />
        <TextView
            android:id="@+id/widget_time_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="40m LEFT"
            android:textColor="#60a5fa"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:baselineAligned="false">

        <!-- Left: Hot Tub -->
        <LinearLayout
            android:id="@+id/hot_tub_zone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.8"
            android:background="@drawable/widget_inset"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOT TUB"
                android:textColor="#60a5fa"
                android:textSize="9sp"
                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/widget_temp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFFFFF"
                                android:textSize="48sp"
                                android:textStyle="bold"
                                android:includeFontPadding="false" />
                            <TextView
                                android:id="@+id/widget_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="READY"
                                android:textColor="#34d399"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:visibility="gone" />        </LinearLayout>

        <ImageView android:layout_width="10dp" android:layout_height="match_parent" android:src="@android:color/transparent" />

        <!-- Right Column: Weather & Hourly -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:orientation="vertical">
            
            <!-- Weather Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="4dp">
                <ImageView
                    android:id="@+id/widget_weather_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_weather_sun" />
                <TextView
                    android:id="@+id/widget_weather_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginLeft="6dp" />
                
                <ImageView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" android:src="@android:color/transparent" />

                <ImageView android:id="@+id/widget_jets_dot" android:layout_width="8dp" android:layout_height="8dp" android:src="@drawable/status_dot" android:layout_marginRight="4dp" />
                <TextView android:id="@+id/widget_jets" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="JETS" android:textColor="#475569" android:textSize="10sp" android:textStyle="bold" android:layout_marginRight="12dp" />
                
                <ImageView android:id="@+id/widget_light_dot" android:layout_width="8dp" android:layout_height="8dp" android:src="@drawable/status_dot" android:layout_marginRight="4dp" />
                <TextView android:id="@+id/widget_light" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LIGHT" android:textColor="#475569" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>

            <ImageView android:layout_width="match_parent" android:layout_height="1dp" android:background="#15ffffff" android:layout_marginBottom="6dp" />

            <!-- Hourly Forecast Row (5 Slots) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">
                
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/h1_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Now" android:textColor="#94a3b8" android:textSize="8sp" />
                    <ImageView android:id="@+id/h1_icon" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_weather_cloud" />
                    <TextView android:id="@+id/h1_temp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°" android:textColor="#FFFFFF" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/h2_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+1h" android:textColor="#94a3b8" android:textSize="8sp" />
                    <ImageView android:id="@+id/h2_icon" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_weather_sun" />
                    <TextView android:id="@+id/h2_temp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°" android:textColor="#FFFFFF" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/h3_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+2h" android:textColor="#94a3b8" android:textSize="8sp" />
                    <ImageView android:id="@+id/h3_icon" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_weather_sun" />
                    <TextView android:id="@+id/h3_temp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°" android:textColor="#FFFFFF" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/h4_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+3h" android:textColor="#94a3b8" android:textSize="8sp" />
                    <ImageView android:id="@+id/h4_icon" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_weather_sun" />
                    <TextView android:id="@+id/h4_temp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°" android:textColor="#FFFFFF" android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/h5_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+4h" android:textColor="#94a3b8" android:textSize="8sp" />
                    <ImageView android:id="@+id/h5_icon" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_weather_sun" />
                    <TextView android:id="@+id/h5_temp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°" android:textColor="#FFFFFF" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Footer: Next Scheduled Event -->
    <TextView
        android:id="@+id/widget_next_event"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NEXT: ---"
        android:textColor="#475569"
        android:textSize="9sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="4dp" />

</LinearLayout>